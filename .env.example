# workagent — 환경변수 예시
# 사용법: cp .env.example .env 한 뒤 실제 값으로 채운다. .env 는 절대 커밋하지 않는다.
# 운영 규범: .agents/AGENTS.md  /  시크릿 규약: .agents/rules/secrets.md

# ─────────────────────────────────────────────────────────────
# 공통
# ─────────────────────────────────────────────────────────────
TZ=Asia/Seoul
RESTART_POLICY=unless-stopped

# ─────────────────────────────────────────────────────────────
# 에이전트 선택 (docker compose profiles)
#   hermes   → hermes-agent 만 기동
#   openclaw → openclaw 만 기동
#   hermes,openclaw → 둘 다 (각각 별도 봇 토큰 필요)
# ─────────────────────────────────────────────────────────────
COMPOSE_PROFILES=hermes

# ─────────────────────────────────────────────────────────────
# Postgres (Mattermost 백엔드 DB)
# ─────────────────────────────────────────────────────────────
POSTGRES_IMAGE_TAG=15-alpine
POSTGRES_USER=mmuser
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=mattermost

# ─────────────────────────────────────────────────────────────
# Mattermost
# ─────────────────────────────────────────────────────────────
# team-edition (오픈소스, MIT) 또는 enterprise-edition (라이선스 필요)
MATTERMOST_IMAGE=mattermost-team-edition
# 명시적 버전 고정 권장 (latest 지양)
MATTERMOST_IMAGE_TAG=10.5
# 호스트에 노출할 포트
MATTERMOST_PORT=8065
# 사용자에게 공개되는 사이트 URL. 리버스 프록시를 쓴다면 https://chat.example.com 형태
MM_SERVICESETTINGS_SITEURL=http://localhost:8065

# ─────────────────────────────────────────────────────────────
# Mattermost — 로컬라이제이션 (기본 한국어)
# 지원 로케일: bg, de, en, en-AU, es, fa, fr, hu, it, ja, ko, nl, pl,
#              pt-br, ro, ru, sv, tr, uk, vi, zh-Hans, zh-Hant
# ─────────────────────────────────────────────────────────────
MM_DEFAULT_LOCALE=ko
# 사용자에게 노출할 언어 목록 (콤마 구분). 비우면 전체 노출. 예: ko,en
MM_AVAILABLE_LOCALES=

# ─────────────────────────────────────────────────────────────
# Mattermost — 커스텀 브랜딩
# 로고 이미지는 환경변수로 주입 불가. 두 가지 경로 중 하나:
#   (a) 시스템 콘솔 > Site Configuration > Customization 에서 업로드
#   (b) volumes/mattermost/data/brand/image.png 에 파일을 두면 즉시 반영
# ─────────────────────────────────────────────────────────────
MM_SITE_NAME=workagent
MM_CUSTOM_BRAND_TEXT=
MM_CUSTOM_DESCRIPTION_TEXT=

# ─────────────────────────────────────────────────────────────
# hermes-agent — 공식 이미지
# ─────────────────────────────────────────────────────────────
# 공식 이미지 태그. 운영에서는 'latest' 대신 명시적 버전 권장 (예: v0.9.0)
HERMES_IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────
# hermes-agent — LLM 공급자 (OpenRouter)
# 키 발급: https://openrouter.ai/keys
# 모델 카탈로그: https://openrouter.ai/models
# ─────────────────────────────────────────────────────────────
HERMES_INFERENCE_PROVIDER=openrouter
# 기본 모델. provider/model 형식 (OpenRouter 모델 슬러그)
HERMES_INFERENCE_MODEL=anthropic/claude-opus-4.7
OPENROUTER_API_KEY=sk-or-changeme
# 선택: 커스텀 OpenRouter 호환 게이트웨이를 쓸 때만 지정. 비우면 공식 엔드포인트 사용
OPENROUTER_BASE_URL=

# ─────────────────────────────────────────────────────────────
# hermes-agent — Mattermost 어댑터
# 사전 작업: Mattermost 시스템 콘솔 > Integrations > Bot Accounts 활성화 후 봇 생성
# ─────────────────────────────────────────────────────────────
# 컨테이너 네트워크 내부 주소 (변경 비권장)
MATTERMOST_URL=http://mattermost:8065
# 봇 personal access token (Bot Accounts 화면에서 1회 노출)
MATTERMOST_TOKEN=changeme-bot-token
# 봇과 대화 가능한 사용자 ID (26자, 콤마 구분). Mattermost 프로필에서 확인
MATTERMOST_ALLOWED_USERS=changeme-user-id

# 선택: 스레드 모드 ("thread" | "off")
MATTERMOST_REPLY_MODE=thread
# 선택: 채널에서 @멘션 없이도 응답할지 ("true" | "false")
MATTERMOST_REQUIRE_MENTION=true
# 선택: cron/공지 메시지를 보낼 기본 채널 ID
MATTERMOST_HOME_CHANNEL=
# 선택: 봇이 응답을 허용하는 채널 ID (콤마 구분, 비우면 전체 허용)
MATTERMOST_ALLOWED_CHANNELS=
# 선택: 멘션 없이도 자유 응답할 채널 ID (콤마 구분)
MATTERMOST_FREE_RESPONSE_CHANNELS=

# ─────────────────────────────────────────────────────────────
# openclaw — 공식 이미지 (ghcr.io/openclaw/openclaw)
# 데이터 디렉터리: 컨테이너 내 /home/node/.openclaw  →  ./volumes/openclaw
# Mattermost / OpenRouter 인증은 위의 변수들을 재사용한다 (compose 가 매핑).
# 채널 정책·모델은 config/openclaw/config.json 에서 관리.
# ─────────────────────────────────────────────────────────────
OPENCLAW_IMAGE_TAG=latest
# Docker bridge 환경에서 mDNS(bonjour) 비활성 권장
OPENCLAW_DISABLE_BONJOUR=1
# Gateway 토큰 (필수, 컨테이너 환경). 임의 32바이트.
#   생성 예: openssl rand -base64 32
OPENCLAW_GATEWAY_TOKEN=changeme-random-32bytes-base64
